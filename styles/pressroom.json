{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Pressroom",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "studio-black",
          "color": "#0E0804",
          "name": "Studio Black"
        },
        {
          "slug": "studio-ink",
          "color": "#1A0E04",
          "name": "Studio Ink"
        },
        {
          "slug": "studio-mid",
          "color": "#88725A",
          "name": "Studio Mid"
        },
        {
          "slug": "studio-rule",
          "color": "#CEC0A0",
          "name": "Studio Rule"
        },
        {
          "slug": "studio-ground",
          "color": "#F0E6CC",
          "name": "Studio Ground"
        },
        {
          "slug": "studio-paper",
          "color": "#FAF3E4",
          "name": "Studio Paper"
        },
        {
          "slug": "studio-press",
          "color": "#6A1C30",
          "name": "Studio Press"
        },
        {
          "slug": "studio-press-tint",
          "color": "#F5E4EC",
          "name": "Studio Press Tint"
        }
      ]
    },
    "custom": {
      "colophon-light": "#F0E6CC",
      "colophon-dark": "#0E0804",
      "colophon-accent": "#6A1C30"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--studio-ground)",
      "text": "var(--wp--preset--color--studio-ink)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--studio-black)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--studio-press)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--studio-black)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--studio-press)",
          "text": "var(--wp--preset--color--studio-paper)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--studio-black)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--studio-ink)"
        }
      }
    }
  }
}
