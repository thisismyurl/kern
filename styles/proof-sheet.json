          "color": "#ece8e0",
          "name": "Studio Ground"
        },
        {
          "slug": "studio-paper",
          "color": "#f8f5ed",
          "name": "Studio Paper"
        },
        {
          "slug": "studio-press",
          "color": "#3a6a9a",
          "name": "Studio Press"
