{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Foundry Dark",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "studio-black",
          "color": "#F5F1E9",
          "name": "Studio Black"
        },
        {
          "slug": "studio-ink",
          "color": "#E8E4D8",
          "name": "Studio Ink"
        },
        {
          "slug": "studio-mid",
          "color": "#8A8072",
          "name": "Studio Mid"
        },
        {
          "slug": "studio-rule",
          "color": "#302C22",
          "name": "Studio Rule"
        },
        {
          "slug": "studio-ground",
          "color": "#111009",
          "name": "Studio Ground"
        },
        {
          "slug": "studio-paper",
          "color": "#1E1C14",
          "name": "Studio Paper"
        },
        {
          "slug": "studio-press",
          "color": "#C8921C",
          "name": "Studio Press"
        },
        {
          "slug": "studio-press-tint",
          "color": "#2A2410",
          "name": "Studio Press Tint"
        }
      ]
    },
    "custom": {
      "colophon-light": "#1E1C14",
      "colophon-dark": "#F5F1E9",
      "colophon-accent": "#C8921C"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--studio-ground)",
      "text": "var(--wp--preset--color--studio-ink)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--studio-black)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--studio-press)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--studio-black)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--studio-press)",
          "text": "var(--wp--preset--color--studio-ground)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--studio-black)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--studio-ink)"
        }
      }
    }
  }
}
