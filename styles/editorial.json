        },
        {
          "slug": "studio-rule",
          "color": "#d4d4d4",
          "name": "Studio Rule"
        },
        {
          "slug": "studio-ground",
          "color": "#e8e8e8",
          "name": "Studio Ground"
        },
        {
          "slug": "studio-paper",
          "color": "#f0f0ee",
          "name": "Studio Paper"
        },
        {
          "slug": "studio-press",
          "color": "#2d5a88",
          "name": "Studio Press"
        },
        {
          "slug": "studio-press-tint",
