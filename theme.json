{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "studio-black",
					"color": "#1a1a1a",
					"name": "Studio Black"
				},
				{
					"slug": "studio-ink",
					"color": "#2e2e2e",
					"name": "Studio Ink"
				},
				{
					"slug": "studio-mid",
					"color": "#6b6b68",
					"name": "Studio Mid"
				},
				{
					"slug": "studio-rule",
					"color": "#d6d3cc",
					"name": "Studio Rule"
				},
				{
					"slug": "studio-ground",
					"color": "#f5f3ee",
					"name": "Studio Ground"
				},
				{
					"slug": "studio-paper",
					"color": "#ffffff",
					"name": "Studio Paper"
				},
				{
					"slug": "studio-press",
					"color": "#1a2f52",
					"name": "Studio Press"
				},
				{
					"slug": "studio-press-tint",
					"color": "#e7ecf4",
					"name": "Studio Press Tint"
				}
			],
			"gradients": []
		},
		"typography": {
			"fluid": true,
			"customFontSize": false,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true,
			"textDecoration": true,
			"fontFamilies": [
				{
					"name": "Fraunces",
					"slug": "fraunces",
					"fontFamily": "Fraunces, Georgia, 'Times New Roman', serif",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fraunces/fraunces-variable.woff2"
							]
						},
						{
							"fontFamily": "Fraunces",
							"fontWeight": "100 900",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fraunces/fraunces-variable-italic.woff2"
							]
						}
					]
				},
				{
					"name": "Plus Jakarta Sans",
					"slug": "jakarta",
					"fontFamily": "'Plus Jakarta Sans', 'Helvetica Neue', Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "200 800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-variable.woff2"
							]
						},
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "200 800",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-variable-italic.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"name": "2X-Small",
					"slug": "2xs",
					"size": "0.6875rem",
					"fluid": false
				},
				{
					"name": "X-Small",
					"slug": "xs",
					"size": "clamp(0.75rem, 0.72rem + 0.15vw, 0.875rem)",
					"fluid": {
						"min": "0.75rem",
						"max": "0.875rem"
					}
				},
				{
					"name": "Small",
					"slug": "sm",
					"size": "clamp(0.875rem, 0.83rem + 0.22vw, 1rem)",
					"fluid": {
						"min": "0.875rem",
						"max": "1rem"
					}
				},
				{
					"name": "Base",
					"slug": "base",
					"size": "clamp(1rem, 0.96rem + 0.22vw, 1.125rem)",
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					}
				},
				{
					"name": "Medium",
					"slug": "md",
					"size": "clamp(1.125rem, 1.07rem + 0.27vw, 1.25rem)",
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					}
				},
				{
					"name": "Large",
					"slug": "lg",
					"size": "clamp(1.25rem, 1.15rem + 0.5vw, 1.5rem)",
					"fluid": {
						"min": "1.25rem",
						"max": "1.5rem"
					}
				},
				{
					"name": "X-Large",
					"slug": "xl",
					"size": "clamp(1.5rem, 1.35rem + 0.75vw, 2rem)",
					"fluid": {
						"min": "1.5rem",
						"max": "2rem"
					}
				},
				{
					"name": "2X-Large",
					"slug": "2xl",
					"size": "clamp(1.75rem, 1.5rem + 1.25vw, 2.5rem)",
					"fluid": {
						"min": "1.75rem",
						"max": "2.5rem"
					}
				},
				{
					"name": "3X-Large",
					"slug": "3xl",
					"size": "clamp(2rem, 1.6rem + 2vw, 3.5rem)",
					"fluid": {
						"min": "2rem",
						"max": "3.5rem"
					}
				},
				{
					"name": "4X-Large",
					"slug": "4xl",
					"size": "clamp(2.5rem, 1.9rem + 3vw, 5rem)",
					"fluid": {
						"min": "2.5rem",
						"max": "5rem"
					}
				},
				{
					"name": "Display",
					"slug": "display",
					"size": "clamp(3rem, 1.8rem + 6vw, 8rem)",
					"fluid": {
						"min": "3rem",
						"max": "8rem"
					}
				}
			]
		},
		"spacing": {
			"customSpacingSize": false,
			"spacingSizes": [
				{
					"name": "1",
					"slug": "1",
					"size": "0.25rem"
				},
				{
					"name": "2",
					"slug": "2",
					"size": "0.5rem"
				},
				{
					"name": "3",
					"slug": "3",
					"size": "0.75rem"
				},
				{
					"name": "4",
					"slug": "4",
					"size": "1rem"
				},
				{
					"name": "5",
					"slug": "5",
					"size": "1.5rem"
				},
				{
					"name": "6",
					"slug": "6",
					"size": "2rem"
				},
				{
					"name": "8",
					"slug": "8",
					"size": "2.5rem"
				},
				{
					"name": "10",
					"slug": "10",
					"size": "3rem"
				},
				{
					"name": "12",
					"slug": "12",
					"size": "4rem"
				},
				{
					"name": "16",
					"slug": "16",
					"size": "6rem"
				},
				{
					"name": "20",
					"slug": "20",
					"size": "8rem"
				},
				{
					"name": "24",
					"slug": "24",
					"size": "10rem"
				}
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1440px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"dimensions": {
			"minHeight": true,
			"aspectRatio": true
		},
		"position": {
			"sticky": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "None",
					"slug": "none",
					"shadow": "none"
				}
			]
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": false
				}
			},
			"core/post-featured-image": {
				"allowResize": false
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--studio-ground)",
			"text": "var(--wp--preset--color--studio-black)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--jakarta)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"fontWeight": "350",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--6)",
			"padding": {
				"left": "var(--wp--preset--spacing--5)",
				"right": "var(--wp--preset--spacing--5)"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--display)",
					"fontWeight": "300",
					"fontOpticalSizing": "auto",
					"lineHeight": "1.05",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-black)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"fontWeight": "400",
					"fontOpticalSizing": "auto",
					"lineHeight": "1.12",
					"letterSpacing": "-0.015em"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-black)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "400",
					"fontOpticalSizing": "auto",
					"lineHeight": "1.18"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-black)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "500",
					"lineHeight": "1.25"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600",
					"letterSpacing": "0.1em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-mid)"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--2xs)",
					"fontWeight": "600",
					"letterSpacing": "0.14em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-mid)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--studio-press)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--studio-black)"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--studio-black)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--studio-press)",
					"text": "var(--wp--preset--color--studio-paper)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600",
					"letterSpacing": "0.04em"
				},
				"border": {
					"radius": "0"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--4)",
						"bottom": "var(--wp--preset--spacing--4)",
						"left": "var(--wp--preset--spacing--6)",
						"right": "var(--wp--preset--spacing--6)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--studio-black)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--studio-black)"
					}
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontWeight": "400",
					"lineHeight": "1.12",
					"textDecoration": "none"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-black)"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"lineHeight": "1.7"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-ink)"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--xs)"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-mid)"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--2xs)",
					"fontWeight": "600",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-press)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--fraunces)",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "400",
					"letterSpacing": "-0.01em",
					"textDecoration": "none"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-black)"
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--2xs)",
					"fontWeight": "400",
					"letterSpacing": "0.1em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--studio-mid)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--jakarta)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500",
					"letterSpacing": "0.03em"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--studio-press)",
					"style": "solid",
					"width": "0 0 0 3px"
				},
				"typography": {
					"fontStyle": "italic"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--2)",
						"bottom": "var(--wp--preset--spacing--2)",
						"left": "var(--wp--preset--spacing--6)",
						"right": "0"
					}
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--studio-rule)"
				},
				"border": {
					"color": "var(--wp--preset--color--studio-rule)",
					"width": "1px"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--studio-press-tint)"
				},
				"border": {
					"color": "var(--wp--preset--color--studio-rule)",
					"radius": "0",
					"style": "solid",
					"width": "1px"
				},
				"typography": {
					"fontFamily": "monospace",
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "post-meta",
			"title": "Post Meta",
			"area": "uncategorized"
		}
	],
	"customTemplates": [
		{
			"name": "page-wide",
			"title": "Page: Wide (no sidebar)",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-blank",
			"title": "Page: Blank (no header/footer)",
			"postTypes": [
				"page"
			]
		}
	]
}
